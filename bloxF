local function pressKey(key)
    VIM:SendKeyEvent(true, key, false, game)
    task.wait(0.05)
    VIM:SendKeyEvent(false, key, false, game)
end

local function getDelay(key)
    if key == "Z" then return DelayZ end
    if key == "X" then return DelayX end
    if key == "C" then return DelayC end
    if key == "V" then return DelayV end
    return 0.3
end

