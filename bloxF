                        boss = getIceBoss()
                    until boss or not AutoSecondSea
                end

                -- ตีบอส
                if boss then
                    local root = boss:FindFirstChild("HumanoidRootPart")
                    repeat task.wait()
                        if not AutoSecondSea then break end

                        if root then
                            player.Character.HumanoidRootPart.CFrame = root.CFrame * CFrame.new(0, 25, 0)
                        end

                        if AttackRemote and HitRemote then
                            AttackRemote:FireServer(0.5)
                            HitRemote:FireServer(root, {}, nil, HIT_KEY)
                        end

                    until boss.Humanoid.Health <= 0 or not AutoSecondSea
                end

                -- กลับไปคุย Detective
