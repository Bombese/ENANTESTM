-- ==============================
-- 💠 ฟังก์ชันหา Chest
-- ==============================
local function getChests()
    local list = {}
    for _, v in pairs(workspace:GetDescendants()) do
        if string.find(v.Name, "Chest") and v:IsA("BasePart") then
            table.insert(list, v)
        end
    end
    return list
end

-- ==============================
-- 💠 ฟังก์ชันรับตัวละคร (กันรีตัว)
-- ==============================
local function getChar()
    local player = Players.LocalPlayer
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then
        char = player.CharacterAdded:Wait()
        char:WaitForChild("HumanoidRootPart")
    end
    return char
end

-- ==============================
-- 💠 บินไป Chest (หยุดทันทีเมื่อปิด)
-- ==============================
local function flyTo(cf)
    local char = getChar()
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local dir = (cf.Position - hrp.Position).Unit
    local dist = (cf.Position - hrp.Position).Magnitude
    local time = dist / SPEED

    local startTime = tick()
    while tick() - startTime < time do
        if not hrp.Parent then break end
        if not AutoChest then return end -- 🔥 หยุดทันที

        hrp.CFrame = CFrame.new(
            hrp.Position + dir * SPEED * RunService.Heartbeat:Wait()
        )
    end

    if hrp.Parent and AutoChest then
        hrp.CFrame = cf
    end
end

-- ==============================
-- 💠 Fluent UI Toggle
-- ==============================
MainTab:AddToggle("AutoChest", {
    Title = "Auto Chest",
    Default = false,
    Callback = function(v)
        AutoChest = v
    end
})

-- ==============================
-- 💠 LOOP ออโต้เก็บ Chest
-- ==============================
task.spawn(function()
    while task.wait(0.5) do
        if AutoChest then
            pcall(function()
                local char = getChar()
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if not hrp then return end

                for _, chest in pairs(getChests()) do
                    if not AutoChest then break end
                    if not chest:IsA("BasePart") then continue end

                    local cf = chest.CFrame * CFrame.new(0, HEIGHT, 0)

                    -- 🕊 บินไป
                    flyTo(cf)
                    if not AutoChest then return end -- 🔥 หยุดทันทีหลังบิน

                    -- 📦 เก็บ
                    if hrp.Parent then
                        hrp.CFrame = chest.CFrame
                        task.wait(0.2)
                        hrp.CFrame = cf
                    end
                end
            end)
        end
    end
end)

