local AutoUpgrade = false

SubTab:AddDropdown("SelectStat", {
    Title = "Select Stat",
    Values = {"Melee", "Defense", "Sword", "Gun", "DevilFruit"},
    Multi = false,
    Default = "Melee", -- ใส่เป็นชื่อค่าเริ่มต้นจะชัดเจนกว่า
    Callback = function(v)
        SelectedStat = v
    end
})

SubTab:AddToggle("AutoUpgradeToggle", { -- ควรใส่ ID ให้ Toggle ด้วย
    Title = "Auto Upgrade",
    Default = false,
    Callback = function(state)
        AutoUpgrade = state
        
        if AutoUpgrade then
            -- ใช้ task.spawn เพื่อไม่ให้ขัดจังหวะการทำงานหลักของ UI
            task.spawn(function()
                while AutoUpgrade do
                    -- ใช้ pcall เผื่อกรณีตัดการเชื่อมต่อหรือ Remote มีปัญหา
                    local success, err = pcall(function()
                        StatRemote:InvokeServer(SelectedStat, 1) -- เพิ่มจำนวน Point ที่ต้องการอัพ (ปกติเกมมักจะถามว่าอัพกี่แต้ม)
                    end)
                    
                    if not success then
                        warn("Upgrade failed:", err)
                    end
                    
                    task.wait(0.5) -- หน่วงเวลาเพื่อไม่ให้ Spam จนเด้ง
                end
            end)
        end
    end
})


