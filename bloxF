local function getIceBoss()
    for _, v in pairs(workspace.Enemies:GetChildren()) do
        if v.Name == "Ice Admiral" and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
            return v
        end
    end
end

-- LOOP
task.spawn(function()
    while task.wait(1) do
        if AutoSecondSea then
            pcall(function()
                local player = Players.LocalPlayer

                -- ไปหา Detective
                flyTo(DETECTIVE)
                task.wait(1)
                CommF:InvokeServer("Talk", "Military Detective")

                -- ไปหาบอส
                local boss = getIceBoss()
                if not boss then
                    flyTo(ICE_BOSS)
