                if not AutoDelivery then break end
            end
        end
    end
end)

-- [2] ระบบเช็ดพื้น 7-11
local function GetPuddle()
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and v.Name == "Puddle" then return v end
    end
end

task.spawn(function()
    while task.wait(0.5) do
        if not Auto711 then continue end
        local char = player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then continue end

        -- เช็คอุปกรณ์ Mop
        local tool = char:FindFirstChildOfClass("Tool") or player.Backpack:FindFirstChildOfClass("Tool")
        if tool then tool.Parent = char else continue end

        local puddle = GetPuddle()
        if puddle then
            TweenTo(puddle.CFrame * CFrame.new(0, 2, 0))
            task.wait(0.3)
            while puddle and puddle.Parent and Auto711 do
                pcall(function() tool:Activate() end)
                task.wait(0.15)
            end
        end
    end
end)

-- [3] ระบบฟาร์มต้นไม้ (PROXY)
local P1, P2 = Vector3.new(195,9,233), Vector3.new(107,9,233)
local P3, P4 = Vector3.new(108,9,168), Vector3.new(195,9,172)
local minX, maxX = math.min(P1.X,P2.X,P3.X,P4.X), math.max(P1.X,P2.X,P3.X,P4.X)
local minZ, maxZ = math.min(P1.Z,P2.Z,P3.Z,P4.Z), math.max(P1.Z,P2.Z,P3.Z,P4.Z)

task.spawn(function()
    while task.wait(0.5) do
        if not AutoFarm then continue end
        local char = player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then continue end

        local trees = {}
        for _, v in ipairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") and v.Name:find("PROXY:") then
                if v.Position.X >= minX and v.Position.X <= maxX and v.Position.Z >= minZ and v.Position.Z <= maxZ then
                    table.insert(trees, v)
                end
            end
        end

        if #trees > 0 then
            local target = trees[math.random(1, #trees)]
            TweenTo(target.CFrame * CFrame.new(2.5, 2, 0))
            task.wait(0.35)
            -- ตรงนี้ต้องมีตัวแปร event ที่คุณใช้ในสคริปต์เดิมด้วยนะครับ
            for i = 1, 25 do
                if not target.Parent or not AutoFarm then break end
                pcall(function() event:FireServer({["\000"] = {target, {Status = "End"}}}, {}) end)
                task.wait(0.04)
            end
        end
    end
end)

