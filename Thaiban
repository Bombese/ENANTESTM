local PathfindingService = game:GetService("PathfindingService")
local player = game.Players.LocalPlayer
local AutoFarm = false

-- ฟังก์ชัน AI เดินตามทางที่โล่ง
local function AI_WalkTo(targetCFrame)
    local char = player.Character
    local hum = char and char:FindFirstChild("Humanoid")
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end

    -- สร้าง Path และคำนวณเส้นทาง
    local path = PathfindingService:CreatePath({
        AgentRadius = 2,
        AgentHeight = 5,
        AgentCanJump = true,
        AgentJumpHeight = 10,
    })

    local success, errorMessage = pcall(function()
        path:ComputeAsync(root.Position, targetCFrame.Position)
    end)

    if success and path.Status == Enum.PathStatus.Success then
        local waypoints = path:GetWaypoints()

        for i, waypoint in ipairs(waypoints) do
            if not AutoFarm then break end -- หยุดเดินถ้าปิด Toggle
            
            -- ถ้าจุดนำทางบอกให้กระโดด
            if waypoint.Action == Enum.PathWaypointAction.Jump then
                hum.Jump = true
            end

            -- สั่งให้เดินไปจุดย่อย
            hum:MoveTo(waypoint.Position)
            
            -- รอจนกว่าจะถึงจุดย่อยนั้น (หรือ Timeout กันบัค)
            local signal = hum.MoveToFinished:Wait(2) 
            if not signal then -- ถ้าติดแหง็กเกิน 2 วิ ให้ลองคำนวณใหม่
                break 
            end
        end
    else
        -- ถ้าคำนวณทางไม่ได้ (เช่น ทางตัน) ให้เดินตรงๆ ไปเลยเป็นทางเลือกสุดท้าย
        hum:MoveTo(targetCFrame.Position)
    end
end

-- ฟังก์ชันหลักสำหรับฟาร์ม
local function StartBananaJob()
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") and v.ActionText == "Interact" then
            -- ใช้ AI เดินไปหา
            AI_WalkTo(v.Parent.CFrame)
            
            task.wait(0.5)
            fireproximityprompt(v)
            task.wait(1)
            break
        end
    end
end

-- Loop รันเบื้องหลัง
task.spawn(function()
    while true do
        task.wait(1)
        if AutoFarm then
            pcall(StartBananaJob)
        end
    end
end)

