local TweenService = game:GetService("TweenService")
local player = game.Players.LocalPlayer
local AutoFarm = false
local TweenSpeed = 15 -- ปรับความเร็วการลอย (ยิ่งน้อยยิ่งเร็ว)

-- ฟังก์ชันสำหรับลอย (Tween) ไปหาจุดหมาย
local function TweenTo(targetCFrame)
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    -- คำนวณระยะทางเพื่อให้ความเร็วคงที่
    local distance = (root.Position - targetCFrame.Position).Magnitude
    local tweenInfo = TweenInfo.new(distance / TweenSpeed, Enum.EasingStyle.Linear)

    local tween = TweenService:Create(root, tweenInfo, {CFrame = targetCFrame})
    tween:Play()
    
    -- รอจนกว่าจะลอยถึง หรือถ้าปิด Toggle ให้หยุดลอยทันที
    repeat 
        task.wait() 
    until tween.PlaybackState == Enum.PlaybackState.Completed or not AutoFarm

    if not AutoFarm then tween:Cancel() end
end

-- ฟังก์ชันหลักสำหรับรันงาน
local function StartBananaJob()
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") and v.ActionText == "Interact" then
            -- ลอยไปหาตำแหน่ง NPC/จุดรับงาน (บวกความสูงนิดนึงกันจมพื้น)
            local targetPos = v.Parent:IsA("BasePart") and v.Parent.CFrame or v.Parent:GetModelCFrame()
            
            TweenTo(targetPos * CFrame.new(0, 3, 0))
            
            task.wait(0.3)
            fireproximityprompt(v)
            task.wait(1)
            break
        end
    end
end

-- Loop ทำงานเบื้องหลัง
task.spawn(function()
    while true do
        task.wait(1)
        if AutoFarm then
            pcall(StartBananaJob)
        end
    end
end)

